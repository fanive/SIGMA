# ========================================
# SIGMA Terminal - Configuration AI
# ========================================

# ━━━ PROVIDER PRINCIPAL ━━━
# Options: gemini | github-copilot | openai | claude
AI_PROVIDER=gemini

# ━━━ CLÉ API GEMINI (si AI_PROVIDER=gemini) ━━━
GEMINI_API_KEY=votre_cle_gemini_ici

# ━━━ CLÉ API GITHUB COPILOT (si AI_PROVIDER=github-copilot) ━━━
# Cette clé donne accès à: GPT-4, GPT-4o, Claude, etc.
GITHUB_COPILOT_API_KEY=votre_cle_github_copilot_ici

# ━━━ MODÈLES À UTILISER ━━━
# Pour Gemini: flash-exp | flash | pro | flash-thinking
# Pour GitHub Copilot (OpenAI): gpt-4-turbo | gpt-4 | gpt-4o | gpt-4o-mini | gpt-3.5
# Pour GitHub Copilot (Claude): opus | sonnet | haiku
STOCK_MODEL=flash-exp
MARKET_MODEL=flash-exp

# ========================================
# DONNÉES FINANCIÈRES (DATA PROVIDERS)
# ========================================

# FINNHUB (Existant)
FINNHUB_API_KEY=votre_cle_finnhub

# MARKETAUX (Existant - News & Sentiment)
MARKETAUX_API_KEY=votre_cle_marketaux

# FINANCIAL MODELING PREP (Fondamental & Valuation)
FMP_API_KEY=votre_cle_fmp

# TWELVE DATA (Technique & Quotes)
TWELVE_DATA_API_KEY=votre_cle_twelve_data

# POLYGON.IO / MASSIVE (Marché & Volume Institutionnel)
POLYGON_API_KEY=votre_cle_polygon

# ========================================
# CONFIGURATION AVANCÉE (Optionnel)
# ========================================
# Endpoint personnalisé (si vous utilisez un proxy)
# CUSTOM_ENDPOINT=https://votre-proxy.com/v1/chat/completions

